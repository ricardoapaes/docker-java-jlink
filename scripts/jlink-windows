#!/bin/sh
# jlink-windows: Generates a Windows JRE using the cross-compilation JMODs.
#
# Usage:
#   jlink-windows --add-modules <modules> --output <dir> [jlink options...]
#
# Default flags applied automatically:
#   --module-path /opt/jmods-windows
#   --strip-debug
#   --no-man-pages
#   --no-header-files
#   --compress=zip-6  (Java 21+) or --compress=2 (Java 11–17, chosen automatically)
#
# The Windows JDK binaries (java.exe, keytool.exe, jvm.dll) are at /opt/jdk-windows.
#
# Example:
#   jlink-windows \
#     --add-modules java.base,java.desktop,java.xml \
#     --output /output/jre-windows

set -e

# --compress syntax changed in Java 21: zip-N (21+) vs numeric 0|1|2 (older)
JAVA_MAJOR=$(/opt/jdk-linux/bin/java -version 2>&1 | sed -n 's/.*version "\([0-9]*\).*/\1/p')
if [ "$JAVA_MAJOR" -ge 21 ] 2>/dev/null; then
    COMPRESS="--compress=zip-6"
else
    COMPRESS="--compress=2"
fi

exec /opt/jdk-linux/bin/jlink \
    --module-path /opt/jmods-windows \
    --strip-debug \
    --no-man-pages \
    --no-header-files \
    $COMPRESS \
    "$@"
